# Database engine — use SQLite for local dev (no MySQL install needed).
# For MySQL, set DB_ENGINE=django.db.backends.mysql and ensure MySQL is running.
DB_ENGINE=django.db.backends.sqlite3

# MySQL settings (only used when DB_ENGINE=django.db.backends.mysql)
DB_NAME=clinic_booking
DB_USER=root
DB_PASSWORD=8520
DB_HOST=localhost
DB_PORT=3306

ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=7

# Email notifications (console = print to Django terminal; smtp = real emails)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=jamesjohnson.a345@gmail.com
EMAIL_HOST_PASSWORD=zafabsbarnsjqosh
DEFAULT_FROM_EMAIL=jamesjohnson.a345@gmail.com

# Google OAuth — same Client ID as NEXT_PUBLIC_GOOGLE_CLIENT_ID in frontend
GOOGLE_CLIENT_ID=564703130153-lri3a6hpei1bgiu7bu4ltnuu55h9gqdp.apps.googleusercontent.com
# Set false on Windows if Python SSL cannot verify Google certificates (local dev only)
GOOGLE_SSL_VERIFY=false